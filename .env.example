# משאוושה — Environment Variables
#
# Copy this file to .env (for local dev) and set the same values in
# Netlify → Site settings → Environment variables (for production).
#
# VITE_* variables are exposed to the browser bundle.
# Variables without VITE_ prefix are server-only (Netlify functions).

# ─── API auth (shared-secret) ────────────────────────────────────────
# Anything random + long. Same value on both sides.
# Used by client → Netlify functions to gate public API endpoints.
# Generate: `openssl rand -hex 32` or any random string ≥32 chars.
VITE_API_TOKEN=
API_TOKEN=

# ─── EmailJS (invoice request emails to suppliers) ───────────────────
# Sign up at https://www.emailjs.com/, create a service + template, then:
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# ─── Netlify Blobs (server-side storage) ─────────────────────────────
# Optional — used as a fallback when the automatic Netlify context is
# unavailable (e.g. local `netlify dev` without linking).
# Get from https://app.netlify.com/user/applications#personal-access-tokens
SITE_ID=
NETLIFY_TOKEN=

# ─── Google OAuth (Gmail integration for invoice retrieval) ──────────
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
